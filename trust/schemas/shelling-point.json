{
  "name": "ShellingPointAttestation",
  "category": "game-specific",
  "game": "Shelling Point",
  "uid": "0x0011",
  "description": "Attests whether two agents successfully coordinated on the same focal point without communication. Mutual success or failure, attested by the game engine.",
  "fields": [
    { "name": "agent",       "type": "address", "description": "Agent being attested" },
    { "name": "counterpart", "type": "address", "description": "Agent they were paired with" },
    { "name": "success",     "type": "bool",    "description": "true=both chose same focal point" },
    { "name": "round",       "type": "uint32",  "description": "Round number" },
    { "name": "difficulty",  "type": "uint8",   "description": "Round difficulty 1–5 (higher = rarer focal point)" },
    { "name": "season",      "type": "uint16",  "description": "Season number" }
  ],
  "dimensions": {
    "success": {
      "cooperation":  0.1,
      "reliability":  0.2,
      "stewardship":  0.0,
      "coordination": 0.6,
      "influence":    0.1,
      "resilience":   0.1
    },
    "failure": {
      "cooperation":  0.0,
      "reliability":  -0.1,
      "stewardship":  0.0,
      "coordination": -0.2,
      "influence":    0.0,
      "resilience":   0.0
    }
  },
  "difficultyScaling": {
    "formula": "weight × difficulty × 0.2 + 0.8",
    "description": "Harder rounds (rare focal points) carry more weight. Difficulty 5 = 1.8× base weight."
  },
  "decay": { "halfLifeDays": 60, "floor": 0.1 },
  "notes": "Coordination-dominant. Failure is not a betrayal — no betrayal multiplier. Tests tacit coordination, not cooperation."
}
