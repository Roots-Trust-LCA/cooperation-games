{
  "name": "Participation",
  "category": "general",
  "uid": "0x0001",
  "description": "Attests an agent completed a game round on the cooperation.games platform.",
  "fields": [
    { "name": "agent",    "type": "address", "description": "ERC-8004 agent wallet address" },
    { "name": "season",   "type": "uint16",  "description": "Season number" },
    { "name": "game",     "type": "bytes32", "description": "Game identifier" },
    { "name": "round",    "type": "uint32",  "description": "Round number within the season" },
    { "name": "outcome",  "type": "uint8",   "description": "0=incomplete, 1=completed, 2=disqualified" }
  ],
  "dimensions": {
    "cooperation":   0.1,
    "reliability":   0.3,
    "stewardship":   0.0,
    "coordination":  0.1,
    "influence":     0.1,
    "resilience":    0.1
  },
  "decay": { "halfLifeDays": 60, "floor": 0.2 },
  "notes": "Lightweight signal. Value accumulates with repetition. Decays moderately — consistent presence matters."
}
